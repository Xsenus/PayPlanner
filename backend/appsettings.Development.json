{
  "ConnectionStrings": {
    "Default": "Data Source=payplanner.db"
  },
  "Jwt": {
    "Key": "dev-super-secret-key-min-32-chars-long-12345",
    "Issuer": "PayPlanner",
    "Audience": "PayPlanner"
  },
  "Backup": {
    "IntervalHours": 6,
    "Directory": "backups",
    "MaxFiles": 50
  },
  "Urls": "http://localhost:5080",
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Seed": {
    "ClientsAndPayments": false
  }
}
